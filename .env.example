# Copia para .env.local (desenvolvimento local) e mete os mesmos valores
# nas Environment Variables do site no Netlify (Site settings → Environment variables).

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Trading212 (App → Settings → API → Generate key, read-only)
TRADING212_API_KEY=

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# Google Drive — Saúde (ver instruções no topo de netlify/functions/health.js)
GOOGLE_SERVICE_ACCOUNT_JSON=
HEALTH_DRIVE_FOLDER_ID=
